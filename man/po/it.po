#| "Passing the number <emphasis remap=\"I\">-1</emphasis> as "
#| "<replaceable>MAX_DAYS</replaceable> will remove checking a password's "
#| "validity."
msgid ""
"Passing the value <_:emphasis-1/> or an empty string as the <_:replaceable-2/"
"> clears the value and removes the password change requirement."
msgstr ""
"Usare il valore <emphasis remap=\"I\">-1</emphasis> come "
"<replaceable>MAX_GIORNI</replaceable> rimuove il controllo sulla validità "
"della password."

